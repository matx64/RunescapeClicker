<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="RunescapeClicker.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:RunescapeClicker.App"
    mc:Ignorable="d">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <ScrollViewer>
        <Grid Padding="28"
              RowSpacing="20"
              ColumnSpacing="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Spacing="12">
                <TextBlock Text="Runescape Clicker Phase 4 Harness"
                           Style="{ThemeResource TitleLargeTextBlockStyle}" />
                <TextBlock Text="{Binding SummaryText}"
                           TextWrapping="WrapWholeWords" />
                <TextBlock Text="{Binding CurrentState}"
                           FontWeight="SemiBold" />
                <InfoBar IsOpen="{Binding Status.IsStatusOpen}"
                         Severity="{Binding Status.StatusSeverity}"
                         IsClosable="False"
                         Message="{Binding Status.StatusMessage}" />
            </StackPanel>

            <Grid Grid.Row="1"
                  ColumnSpacing="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0"
                            Spacing="16">
                    <Border Padding="16"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="12">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Automation Services"
                                       Style="{ThemeResource TitleMediumTextBlockStyle}" />
                            <TextBlock Text="{Binding Status.HotkeyStatusText}"
                                       TextWrapping="WrapWholeWords" />
                            <TextBlock Text="{Binding Status.LastHotkeyText}"
                                       TextWrapping="WrapWholeWords" />
                            <Button Content="Retry Hotkeys"
                                    Command="{Binding RetryHotkeysCommand}" />
                        </StackPanel>
                    </Border>

                    <Border Padding="16"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="12">
                        <StackPanel Spacing="12">
                            <TextBlock Text="Action Composer"
                                       Style="{ThemeResource TitleMediumTextBlockStyle}" />
                            <StackPanel Orientation="Horizontal"
                                        Spacing="8">
                                <Button Content="Add Mouse Click"
                                        Command="{Binding ActionComposer.BeginAddMouseClickCommand}" />
                                <Button Content="Add Key Press"
                                        Command="{Binding ActionComposer.BeginAddKeyPressCommand}" />
                                <Button Content="Add Delay"
                                        Command="{Binding ActionComposer.BeginAddDelayCommand}" />
                            </StackPanel>

                            <StackPanel Visibility="{Binding ActionComposer.IsMouseDraftActive, Converter={StaticResource BooleanToVisibilityConverter}}"
                                        Spacing="8">
                                <TextBlock Text="{Binding ActionComposer.DraftTitle}"
                                           FontWeight="SemiBold" />
                                <ComboBox Header="Mouse Button"
                                          ItemsSource="{Binding ActionComposer.MouseButtonOptions}"
                                          SelectedItem="{Binding ActionComposer.SelectedMouseButton, Mode=TwoWay}" />
                                <TextBlock Text="{Binding Status.PickedCoordinateText}"
                                           TextWrapping="WrapWholeWords" />
                                <StackPanel Orientation="Horizontal"
                                            Spacing="8">
                                    <Button Content="Capture Current Cursor (F1)"
                                            Command="{Binding ActionComposer.CaptureCurrentCursorCommand}" />
                                    <Button Content="Pick On Screen"
                                            Command="{Binding ActionComposer.PickOnScreenCommand}" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal"
                                            Spacing="8">
                                    <Button Content="{Binding ActionComposer.ConfirmDraftText}"
                                            Command="{Binding ActionComposer.ConfirmDraftCommand}" />
                                    <Button Content="Cancel"
                                            Command="{Binding ActionComposer.CancelDraftCommand}" />
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Visibility="{Binding ActionComposer.IsKeyDraftActive, Converter={StaticResource BooleanToVisibilityConverter}}"
                                        Spacing="8">
                                <TextBlock Text="{Binding ActionComposer.DraftTitle}"
                                           FontWeight="SemiBold" />
                                <ComboBox Header="Key"
                                          ItemsSource="{Binding ActionComposer.AvailableKeys}"
                                          DisplayMemberPath="DisplayLabel"
                                          SelectedItem="{Binding ActionComposer.SelectedKeyOption, Mode=TwoWay}" />
                                <StackPanel Orientation="Horizontal"
                                            Spacing="8">
                                    <Button Content="{Binding ActionComposer.ConfirmDraftText}"
                                            Command="{Binding ActionComposer.ConfirmDraftCommand}" />
                                    <Button Content="Cancel"
                                            Command="{Binding ActionComposer.CancelDraftCommand}" />
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Visibility="{Binding ActionComposer.IsDelayDraftActive, Converter={StaticResource BooleanToVisibilityConverter}}"
                                        Spacing="8">
                                <TextBlock Text="{Binding ActionComposer.DraftTitle}"
                                           FontWeight="SemiBold" />
                                <TextBox Header="Delay (ms)"
                                         Text="{Binding ActionComposer.DelayMillisecondsText, Mode=TwoWay}" />
                                <StackPanel Orientation="Horizontal"
                                            Spacing="8">
                                    <Button Content="{Binding ActionComposer.ConfirmDraftText}"
                                            Command="{Binding ActionComposer.ConfirmDraftCommand}" />
                                    <Button Content="Cancel"
                                            Command="{Binding ActionComposer.CancelDraftCommand}" />
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Padding="16"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="12">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Sequence"
                                       Style="{ThemeResource TitleMediumTextBlockStyle}" />
                            <ListView ItemsSource="{Binding ActionList.Items}"
                                      Height="260">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid ColumnSpacing="8"
                                              Padding="0,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Text="{Binding DisplayIndex}"
                                                       VerticalAlignment="Center"
                                                       FontWeight="SemiBold" />
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Summary}"
                                                       TextWrapping="WrapWholeWords"
                                                       VerticalAlignment="Center" />
                                            <Button Grid.Column="2"
                                                    Content="Edit"
                                                    Command="{Binding EditCommand}" />
                                            <Button Grid.Column="3"
                                                    Content="Delete"
                                                    Command="{Binding DeleteCommand}" />
                                            <Button Grid.Column="4"
                                                    Content="Up"
                                                    Command="{Binding MoveUpCommand}" />
                                            <Button Grid.Column="5"
                                                    Content="Down"
                                                    Command="{Binding MoveDownCommand}" />
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                            <Button Content="Clear Actions"
                                    Command="{Binding ActionList.ClearActionsCommand}" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Spacing="16">
                    <Border Padding="16"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="12">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Run Controls"
                                       Style="{ThemeResource TitleMediumTextBlockStyle}" />
                            <TextBlock Text="{Binding Status.RunStatusText}"
                                       TextWrapping="WrapWholeWords" />
                            <ComboBox Header="Stop Rule"
                                      ItemsSource="{Binding RunPanel.StopModeOptions}"
                                      SelectedItem="{Binding RunPanel.SelectedStopMode, Mode=TwoWay}" />
                            <TextBox Header="Timer (seconds)"
                                     IsEnabled="{Binding RunPanel.IsTimerStopEnabled}"
                                     Text="{Binding RunPanel.TimerSecondsText, Mode=TwoWay}" />
                            <ProgressRing Width="28"
                                          Height="28"
                                          IsActive="{Binding RunPanel.IsBusy}" />
                            <StackPanel Orientation="Horizontal"
                                        Spacing="8">
                                <Button Content="Start Session Run"
                                        Command="{Binding RunPanel.StartRunCommand}" />
                                <Button Content="Stop Run (F2)"
                                        Command="{Binding RunPanel.StopRunCommand}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Padding="16"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="12">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Manual Smoke"
                                       Style="{ThemeResource TitleMediumTextBlockStyle}" />
                            <TextBlock Text="The Phase 3 smoke actions remain available while Phase 4 moves state and execution behind view models."
                                       TextWrapping="WrapWholeWords" />
                            <Button Content="Start Safe F24 Smoke"
                                    Command="{Binding RunPanel.StartSafeSmokeCommand}" />
                            <Button Content="Run Opt-In Mouse Smoke"
                                    Command="{Binding RunPanel.RunMouseSmokeCommand}" />
                        </StackPanel>
                    </Border>

                    <Border Padding="16"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="12">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Live Log"
                                       Style="{ThemeResource TitleMediumTextBlockStyle}" />
                            <TextBox Height="320"
                                     IsReadOnly="True"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     Text="{Binding Status.LogText}" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Grid>
    </ScrollViewer>
</Window>
