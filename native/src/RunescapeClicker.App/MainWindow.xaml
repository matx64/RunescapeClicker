<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="RunescapeClicker.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:sys="using:System"
    mc:Ignorable="d">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <ScrollViewer>
        <Grid Padding="24"
              RowSpacing="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Spacing="6">
                <TextBlock Text="Runescape Clicker"
                           Style="{ThemeResource TitleLargeTextBlockStyle}" />
                <TextBlock Text="{Binding SummaryText}"
                           TextWrapping="WrapWholeWords" />
                <TextBlock Text="{Binding CurrentState}"
                           FontWeight="SemiBold" />
            </StackPanel>

            <InfoBar Grid.Row="1"
                     IsOpen="{Binding Status.IsStatusOpen}"
                     Severity="{Binding Status.StatusSeverity}"
                     IsClosable="False"
                     Message="{Binding Status.StatusMessage}" />

            <CommandBar Grid.Row="2"
                        DefaultLabelPosition="Right"
                        IsDynamicOverflowEnabled="True">
                <AppBarButton Label="Mouse Click"
                              Command="{Binding ActionComposer.BeginAddMouseClickCommand}">
                    <AppBarButton.Icon>
                        <SymbolIcon Symbol="Add" />
                    </AppBarButton.Icon>
                </AppBarButton>
                <AppBarButton Label="Key Press"
                              Command="{Binding ActionComposer.BeginAddKeyPressCommand}">
                    <AppBarButton.Icon>
                        <SymbolIcon Symbol="Edit" />
                    </AppBarButton.Icon>
                </AppBarButton>
                <AppBarButton Label="Delay"
                              Command="{Binding ActionComposer.BeginAddDelayCommand}">
                    <AppBarButton.Icon>
                        <SymbolIcon Symbol="Preview" />
                    </AppBarButton.Icon>
                </AppBarButton>
                <AppBarSeparator />
                <AppBarButton Label="Clear Sequence"
                              Command="{Binding ActionList.ClearActionsCommand}">
                    <AppBarButton.Icon>
                        <SymbolIcon Symbol="Delete" />
                    </AppBarButton.Icon>
                </AppBarButton>
                <CommandBar.SecondaryCommands>
                    <AppBarButton Label="Retry Hotkeys"
                                  Command="{Binding RetryHotkeysCommand}">
                        <AppBarButton.Icon>
                            <SymbolIcon Symbol="Refresh" />
                        </AppBarButton.Icon>
                    </AppBarButton>
                </CommandBar.SecondaryCommands>
            </CommandBar>

            <Grid Grid.Row="3"
                  x:Name="WorkspaceGrid"
                  RowSpacing="16"
                  ColumnSpacing="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="LeftPaneColumn"
                                      Width="*" />
                    <ColumnDefinition x:Name="RightPaneColumn"
                                      Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Row="0"
                            Grid.Column="0"
                            Spacing="16">
                    <Border Padding="16"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="12">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Automation Status"
                                       Style="{ThemeResource TitleMediumTextBlockStyle}" />
                            <TextBlock Text="{Binding Status.HotkeyStatusText}"
                                       TextWrapping="WrapWholeWords" />
                            <TextBlock Text="{Binding Status.LastHotkeyText}"
                                       TextWrapping="WrapWholeWords"
                                       Opacity="0.75" />
                            <TextBlock Text="F1 captures the current cursor while a mouse action draft is open. F2 stops an active run."
                                       TextWrapping="WrapWholeWords"
                                       Opacity="0.75" />
                        </StackPanel>
                    </Border>

                    <Border Padding="16"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="12">
                        <Grid RowSpacing="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <StackPanel Spacing="6">
                                <TextBlock Text="Action Composer"
                                           Style="{ThemeResource TitleMediumTextBlockStyle}" />
                                <TextBlock Text="{Binding ActionComposer.DraftTitle}"
                                           FontWeight="SemiBold"
                                           Visibility="{Binding ActionComposer.IsDraftOpen, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                <TextBlock Text="Choose an action type from the command bar, then confirm it into the ordered sequence."
                                           TextWrapping="WrapWholeWords"
                                           Opacity="0.75" />
                            </StackPanel>

                            <StackPanel Grid.Row="1"
                                        Spacing="14">
                                <StackPanel Spacing="10"
                                            Visibility="{Binding ActionComposer.IsMouseDraftActive, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <ComboBox Header="Mouse Button"
                                              ItemsSource="{Binding ActionComposer.MouseButtonOptions}"
                                              SelectedItem="{Binding ActionComposer.SelectedMouseButton, Mode=TwoWay}" />
                                    <Border Padding="12"
                                            CornerRadius="8"
                                            BorderThickness="1"
                                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                                        <StackPanel Spacing="4">
                                            <TextBlock Text="Selected Point"
                                                       FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding Status.PickedCoordinateText}"
                                                       TextWrapping="WrapWholeWords" />
                                        </StackPanel>
                                    </Border>
                                    <StackPanel Orientation="Horizontal"
                                                Spacing="8">
                                        <Button Content="Capture Current Cursor (F1)"
                                                Command="{Binding ActionComposer.CaptureCurrentCursorCommand}"
                                                ToolTipService.ToolTip="Use the live cursor position without opening the picker." />
                                        <Button Content="Pick On Screen"
                                                Command="{Binding ActionComposer.PickOnScreenCommand}"
                                                ToolTipService.ToolTip="Open the full-screen picker and click the destination point." />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal"
                                                Spacing="8">
                                        <Button Content="{Binding ActionComposer.ConfirmDraftText}"
                                                Command="{Binding ActionComposer.ConfirmDraftCommand}" />
                                        <Button Content="Cancel"
                                                Command="{Binding ActionComposer.CancelDraftCommand}" />
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Spacing="10"
                                            Visibility="{Binding ActionComposer.IsKeyDraftActive, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <Border x:Name="KeyCaptureAnchor"
                                            Padding="12"
                                            CornerRadius="8"
                                            BorderThickness="1"
                                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                                        <StackPanel Spacing="6">
                                            <TextBlock Text="Captured Key"
                                                       FontWeight="SemiBold" />
                                            <TextBox IsReadOnly="True"
                                                     Text="{Binding ActionComposer.CapturedKeyText}" />
                                            <TextBlock Text="{Binding ActionComposer.KeyCaptureHintText}"
                                                       TextWrapping="WrapWholeWords"
                                                       Opacity="0.75" />
                                        </StackPanel>
                                    </Border>
                                    <StackPanel Orientation="Horizontal"
                                                Spacing="8">
                                        <Button x:Name="CaptureKeyButton"
                                                Content="Capture Key"
                                                Command="{Binding ActionComposer.BeginKeyCaptureCommand}"
                                                ToolTipService.ToolTip="After clicking this button, press the key you want to store." />
                                        <Button Content="Clear"
                                                Command="{Binding ActionComposer.ClearCapturedKeyCommand}" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal"
                                                Spacing="8">
                                        <Button Content="{Binding ActionComposer.ConfirmDraftText}"
                                                Command="{Binding ActionComposer.ConfirmDraftCommand}" />
                                        <Button Content="Cancel"
                                                Command="{Binding ActionComposer.CancelDraftCommand}" />
                                    </StackPanel>
                                    <TeachingTip Target="{Binding ElementName=CaptureKeyButton}"
                                                 Title="Press a key now"
                                                 Subtitle="The next key press in this window will be captured with Windows virtual-key and scan-code metadata."
                                                 IsOpen="{Binding ActionComposer.IsAwaitingKeyCapture}"
                                                 IsLightDismissEnabled="False"
                                                 PreferredPlacement="Bottom" />
                                </StackPanel>

                                <StackPanel Spacing="10"
                                            Visibility="{Binding ActionComposer.IsDelayDraftActive, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <NumberBox Header="Delay (ms)"
                                               SmallChange="100"
                                               Minimum="0"
                                               SpinButtonPlacementMode="Compact"
                                               Text="{Binding ActionComposer.DelayMillisecondsText, Mode=TwoWay}" />
                                    <StackPanel Orientation="Horizontal"
                                                Spacing="8">
                                        <Button Content="{Binding ActionComposer.ConfirmDraftText}"
                                                Command="{Binding ActionComposer.ConfirmDraftCommand}" />
                                        <Button Content="Cancel"
                                                Command="{Binding ActionComposer.CancelDraftCommand}" />
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>

                <StackPanel x:Name="RightPaneStack"
                            Grid.Row="1"
                            Grid.Column="0"
                            Spacing="16">
                    <Border Padding="16"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="12">
                        <StackPanel Spacing="10">
                            <TextBlock Text="Sequence"
                                       Style="{ThemeResource TitleMediumTextBlockStyle}" />
                            <TextBlock Text="Drag items to reorder them. Editing and reordering are disabled while a run is active."
                                       TextWrapping="WrapWholeWords"
                                       Opacity="0.75" />
                            <TextBlock Text="No actions yet. Use the command bar to add a mouse click, key press, or delay."
                                       TextWrapping="WrapWholeWords"
                                       Visibility="{Binding ActionList.ShowEmptyState, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            <ListView ItemsSource="{Binding ActionList.Items}"
                                      AllowDrop="True"
                                      CanDragItems="{Binding ActionList.CanModifyActions}"
                                      CanReorderItems="{Binding ActionList.CanModifyActions}"
                                      DragItemsCompleted="OnSequenceDragItemsCompleted"
                                      Visibility="{Binding ActionList.HasActions, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,8"
                                                Padding="12"
                                                CornerRadius="10"
                                                BorderThickness="1"
                                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                                            <Grid ColumnSpacing="10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <FontIcon Glyph="&#xE8C8;"
                                                          VerticalAlignment="Top"
                                                          Opacity="0.7" />
                                                <StackPanel Grid.Column="1"
                                                            Spacing="2">
                                                    <TextBlock Text="{Binding DisplayIndex}"
                                                               FontWeight="SemiBold" />
                                                    <TextBlock Text="{Binding Summary}"
                                                               TextWrapping="WrapWholeWords" />
                                                </StackPanel>
                                                <Button Grid.Column="2"
                                                        Command="{Binding EditCommand}"
                                                        ToolTipService.ToolTip="Edit this action">
                                                    <SymbolIcon Symbol="Edit" />
                                                </Button>
                                                <Button Grid.Column="3"
                                                        Command="{Binding DeleteCommand}"
                                                        ToolTipService.ToolTip="Remove this action">
                                                    <SymbolIcon Symbol="Delete" />
                                                </Button>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>
                    </Border>

                    <Border Padding="16"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="12">
                        <StackPanel Spacing="12">
                            <TextBlock Text="Run Configuration"
                                       Style="{ThemeResource TitleMediumTextBlockStyle}" />
                            <RadioButtons SelectedIndex="{Binding RunPanel.StopModeIndex, Mode=TwoWay}">
                                <sys:String>Stop on F2 only</sys:String>
                                <sys:String>Stop after timer</sys:String>
                            </RadioButtons>
                            <NumberBox Header="Timer (seconds)"
                                       Minimum="1"
                                       SmallChange="5"
                                       SpinButtonPlacementMode="Compact"
                                       IsEnabled="{Binding RunPanel.IsTimerStopEnabled}"
                                       Text="{Binding RunPanel.TimerSecondsText, Mode=TwoWay}" />
                        </StackPanel>
                    </Border>

                    <Border Padding="16"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="12">
                        <StackPanel Spacing="12">
                            <TextBlock Text="Run Controls"
                                       Style="{ThemeResource TitleMediumTextBlockStyle}" />
                            <StackPanel Orientation="Horizontal"
                                        Spacing="10">
                                <ProgressRing Width="24"
                                              Height="24"
                                              IsActive="{Binding RunPanel.IsBusy}" />
                                <TextBlock Text="{Binding Status.RunStatusText}"
                                           TextWrapping="WrapWholeWords"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0"
                                        MinHeight="48"
                                        Command="{Binding RunPanel.StartRunCommand}"
                                        Content="Start Session Run"
                                        ToolTipService.ToolTip="Begin the configured sequence with the selected stop rule." />
                                <Button Grid.Column="1"
                                        MinHeight="48"
                                        Command="{Binding RunPanel.StopRunCommand}"
                                        Content="Stop Run (F2)"
                                        ToolTipService.ToolTip="Request a stop immediately, or press F2 globally." />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Padding="16"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="12">
                        <StackPanel Spacing="10">
                            <TextBlock Text="Validation"
                                       Style="{ThemeResource TitleMediumTextBlockStyle}" />
                            <TextBlock Text="The safe F24 smoke run and the opt-in mouse smoke run stay available for local Windows validation."
                                       TextWrapping="WrapWholeWords"
                                       Opacity="0.75" />
                            <Button Content="Start Safe F24 Smoke"
                                    Command="{Binding RunPanel.StartSafeSmokeCommand}" />
                            <Button Content="Run Opt-In Mouse Smoke"
                                    Command="{Binding RunPanel.RunMouseSmokeCommand}" />
                        </StackPanel>
                    </Border>

                    <Border Padding="16"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="12">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Live Log"
                                       Style="{ThemeResource TitleMediumTextBlockStyle}" />
                            <TextBox MinHeight="220"
                                     IsReadOnly="True"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     Text="{Binding Status.LogText}" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Grid>
    </ScrollViewer>
</Window>
